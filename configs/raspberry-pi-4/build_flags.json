{
  "mcpu": "cortex-a72",
  "march": "armv8-a",
  "lto": true,
  "lto_mode": "auto",
  "vectorization": true,
  "cmake_args": [
    "-DCMAKE_CXX_FLAGS=-mcpu=cortex-a72 -O3 -flto=auto -march=armv8-a",
    "-DCMAKE_C_FLAGS=-mcpu=cortex-a72 -O3 -flto=auto -march=armv8-a"
  ],
  "env": {
    "CFLAGS": "-mcpu=cortex-a72 -O3 -flto=auto",
    "CXXFLAGS": "-mcpu=cortex-a72 -O3 -flto=auto"
  }
}